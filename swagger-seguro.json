{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Cadastro de Usuarios (Segura)",
    "version": "1.0.0",
    "description": "Versao segura da mesma API vitima. As mesmas operacoes, sem exfiltracao de dados.\n\n---\n\n### Passo a passo\n\n1. Inicie esta API: `npm run segura`\n2. Execute os mesmos endpoints da API vitima\n3. Observe: a senha retorna como hash bcrypt, nao texto puro\n4. Verifique o dashboard do atacante em http://localhost:3001 — nenhum dado aparece\n5. Use os endpoints de `/seguranca` para ver as protecoes aplicadas"
  },
  "servers": [{ "url": "http://localhost:3002" }],
  "tags": [
    { "name": "Usuarios", "description": "Cadastro e validacao — sem exfiltracao de dados." },
    { "name": "Utilitarios", "description": "Funcoes utilitarias usando lib interna da equipe." },
    { "name": "Seguranca", "description": "Mostram as protecoes aplicadas. Use na apresentacao para explicar cada camada." }
  ],
  "paths": {
    "/usuarios/cadastrar": {
      "post": {
        "tags": ["Usuarios"],
        "summary": "Cadastrar usuario — senha protegida com hash bcrypt",
        "description": "Use o CPF `52998224725` (valido). A senha retorna como hash irreversivel. O dashboard do atacante nao recebe nada.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nome", "email", "cpf", "senha"],
                "properties": {
                  "nome": { "type": "string", "example": "joao da silva" },
                  "email": { "type": "string", "example": "joao.silva@email.com" },
                  "cpf": { "type": "string", "example": "52998224725" },
                  "telefone": { "type": "string", "example": "(11) 99999-8888" },
                  "senha": { "type": "string", "example": "minhaSenhaSecreta123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario cadastrado com senha em hash bcrypt" },
          "400": { "description": "Erro de validacao" }
        }
      }
    },
    "/usuarios/validar-cpf": {
      "post": {
        "tags": ["Usuarios"],
        "summary": "Validar CPF — verifica digitos verificadores, sem envio externo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cpf"],
                "properties": {
                  "cpf": { "type": "string", "example": "52998224725" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Resultado da validacao" } }
      }
    },
    "/utilidades/sanitizar": {
      "post": {
        "tags": ["Utilitarios"],
        "summary": "Sanitizar texto — apenas remove caracteres perigosos, sem varredura de dados",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["texto"],
                "properties": {
                  "texto": { "type": "string", "example": "Meu email eh joao@empresa.com e meu CPF 123.456.789-00" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Texto sanitizado" } }
      }
    },
    "/utilidades/capitalizar": {
      "post": {
        "tags": ["Utilitarios"],
        "summary": "Capitalizar texto",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["texto"],
                "properties": {
                  "texto": { "type": "string", "example": "exemplo de texto para capitalizar" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Texto capitalizado" } }
      }
    },
    "/utilidades/gerar-slug": {
      "post": {
        "tags": ["Utilitarios"],
        "summary": "Gerar slug",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["texto"],
                "properties": {
                  "texto": { "type": "string", "example": "Titulo do Meu Artigo!" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Slug gerado" } }
      }
    },
    "/utilidades/mascarar-email": {
      "post": {
        "tags": ["Utilitarios"],
        "summary": "Mascarar email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "example": "joao.silva@email.com" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Email mascarado" } }
      }
    },
    "/seguranca/headers": {
      "get": {
        "tags": ["Seguranca"],
        "summary": "Ver headers HTTP configurados pelo Helmet",
        "description": "Para ver os headers reais: F12 > Network > clique em qualquer requisicao > aba Headers.",
        "responses": { "200": { "description": "Headers de seguranca ativos" } }
      }
    },
    "/seguranca/comparativo": {
      "get": {
        "tags": ["Seguranca"],
        "summary": "Comparativo: API Vitima vs API Segura",
        "responses": { "200": { "description": "Tabela comparativa" } }
      }
    },
    "/saude": {
      "get": {
        "tags": ["Seguranca"],
        "summary": "Status da API e ferramentas ativas",
        "responses": { "200": { "description": "API online" } }
      }
    }
  }
}
